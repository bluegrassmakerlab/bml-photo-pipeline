{
  "remote_root": "onedrive:Bluegrass Maker Lab/Product Photo Pipeline",
  "folders": {
    "incoming": "00_Incoming",
    "etsy_main": "10_Ready/Etsy_Main",
    "etsy_gallery": "10_Ready/Etsy_Gallery",
    "social_4x5": "10_Ready/Social_4x5",
    "social_9x16": "10_Ready/Social_9x16",
    "etsy_video": "10_Ready/Etsy_Video",
    "social_reels": "10_Ready/Social_Reels",
    "video_thumbnail": "10_Ready/Video_Thumbnails",
    "posting_pack": "10_Ready/Posting_Packs",
    "upload_ready": "30_Upload_Ready",
    "needs_review": "20_Needs_Review",
    "archive_originals": "90_Archive/Originals"
  },
  "local_work_dir": "work",
  "state_file": "state/processed.json",
  "incoming_recursive": true,
  "supported_image_extensions": [".jpg", ".jpeg", ".png", ".webp", ".heic", ".heif"],
  "supported_video_extensions": [".mp4", ".mov", ".m4v"],
  "processing": {
    "white_balance": true,
    "white_balance_strength": 0.85,
    "max_source_dimension": 3200,
    "auto_rotate": true,
    "auto_rotate_max_degrees": 5,
    "trim_background": true,
    "trim_threshold": 22,
    "trim_padding_percent": 0.08,
    "center_subject": true,
    "subject_threshold": 22,
    "subject_padding_percent": 0.16,
    "subject_saturation_threshold": 45,
    "normalize_subject_brightness": true,
    "target_subject_luminance": 150,
    "max_subject_brightness_adjustment": 0.45,
    "autocontrast_luminance": true,
    "autocontrast_cutoff": 0.35,
    "brightness": 1.02,
    "contrast": 1.04,
    "color": 1.0,
    "sharpness": 1.1,
    "remove_background": false,
    "background_color": [248, 248, 245]
  },
  "image_exports": {
    "etsy_main": { "width": 2000, "height": 2000 },
    "etsy_gallery": { "width": 2000, "height": 1500 },
    "social_4x5": { "width": 1600, "height": 2000 },
    "social_9x16": { "width": 1440, "height": 2560 }
  },
  "video_processing": {
    "max_duration_seconds": 12,
    "crf": 23,
    "preset": "veryfast"
  },
  "video_exports": {
    "etsy_video": { "width": 1080, "height": 1080 },
    "social_reels": { "width": 1080, "height": 1920 }
  },
  "video_thumbnail": {
    "width": 2000,
    "height": 2000,
    "timestamp_seconds": 1
  },
  "posting_pack": {
    "enabled": true,
    "contact_sheet_width": 2200,
    "thumbnail_width": 420,
    "thumbnail_height": 420
  },
  "upload_ready": {
    "enabled": true,
    "default_product_name": "3D Printed Product",
    "default_price": "",
    "default_quantity": "",
    "default_sku": "",
    "default_material": "3D printed plastic / PLA",
    "shop_name": "Bluegrass Maker Lab",
    "max_auto_images": 4,
    "max_auto_videos": 1,
    "require_product_match": true,
    "tracker_db_path": "../../3d-print-tracker/tracker.db",
    "minimum_product_match_score": 0.75,
    "vision_match_enabled": true,
    "vision_model": "openai/gpt-5.5",
    "vision_minimum_confidence": 0.9,
    "vision_timeout_seconds": 120
  }
}
